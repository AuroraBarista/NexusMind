{
    "manifest_version": 3,
    "name": "NexusMind Uplink",
    "version": "1.0",
    "description": "Capture thoughts and web content directly to NexusMind Terminal.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "icons": {
        "128": "icon.png"
    },
    "host_permissions": [
        "http://localhost:3000/*"
    ]
}